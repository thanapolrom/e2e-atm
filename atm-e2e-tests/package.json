    "logs:nv200": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File .\\capture-nv200-network-log.ps1",
    "proxy:payout": "node proxy-payout.js",
    "proxy:payout:5004": "node -e \"process.env.PAYOUT_PROXY_PORT='5004';require('./proxy-payout')\"",
    "proxy:acceptor": "node proxy-acceptor.js",
    "acceptor": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File .\\run-acceptor.ps1",
    "package": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File .\\run-withdraw.ps1 -Spec .\\test\\specs\\package.spec.js",
